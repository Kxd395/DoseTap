#!/bin/bash

set -euo pipefail

source "$(cd "$(dirname "$0")" && pwd)/dt-common.sh"

dt_require_tool xcrun

command_name="${1:-list}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$command_name" in
  list)
    exec xcrun devicectl list devices
    ;;
  install)
    app_path="${1:-}"
    device_id="${2:-}"
    if [[ -z "$app_path" || -z "$device_id" ]]; then
      echo "Usage: dt-device install <app-path> <device-identifier>" >&2
      exit 1
    fi
    exec xcrun devicectl device install app --device "$device_id" "$app_path"
    ;;
  *)
    echo "Usage: dt-device [list|install <app-path> <device-identifier>]" >&2
    exit 1
    ;;
esac
